# ===== REQUIRED for basic functionality =====
# Without these, the app works using seed data (15 cards) but no Supabase, no scraping, no AI

# Supabase (create project at supabase.com — 2 mins)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key

# Anthropic API (for AI redemption strategy + scraper parsing)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ===== ADMIN PANEL =====
ADMIN_PASSWORD=change-this-in-production

# ===== CRON / SCRAPER =====
# Used by Vercel Cron to auth /api/scrape requests
CRON_SECRET=generate-a-random-string-here

# ===== AFFILIATE IDs (apply for these — takes 3-14 days) =====
# Aggregators
PAISABAZAAR_PARTNER_ID=
BANKBAZAAR_PARTNER_ID=
CASHKARO_PARTNER_ID=

# Direct bank affiliates (higher payout, slower approval)
HDFC_AFFILIATE_ID=
SBI_AFFILIATE_ID=
AXIS_AFFILIATE_ID=
ICICI_AFFILIATE_ID=
